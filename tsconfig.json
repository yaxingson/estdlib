{
  "compilerOptions": {
    "target": "es2015",
    "module": "esnext",

    "allowJs":true,

    "moduleResolution": "node10",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,

    "outDir":"dist",
    "declarationMap":false,

    "types":[],
    "typeRoots":[]
  },
  "include":["lib/**/*", "index.ts"]
}
